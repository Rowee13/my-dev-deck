      "js-yaml@<3.14.2": "3.14.2",
      "js-yaml@>=4.0.0 <4.1.1": "4.1.1",
      "ajv@<6.14.0": "6.14.0",
      "ajv@>=7.0.0-alpha.0 <8.18.0": "8.18.0",
      "qs@<6.14.2": "6.14.2",
